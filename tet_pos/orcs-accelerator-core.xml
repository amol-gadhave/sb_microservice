<project name="orcs-accelerator-core" basedir=".">

	<!-- load custom properties if present (global [ie. in this project] first, 
		then local to the project) -->
	<property name="build.overrides.properties.filename" value="buildoverrides.properties" />
	<property name="build.overrides.local.properties.filename" value="buildoverrides.local.properties" />

	<!-- locate this project -->
	<dirname property="core.project.dir" file="${ant.file.template-core}" />
	<basename property="core.project.name" file="${core.project.dir}" />

	<property file="${core.project.dir}/${build.overrides.properties.filename}" />
	<property file="${basedir}/${build.overrides.local.properties.filename}" />
	<property file="${basedir}/${build.overrides.properties.filename}" />

	<!-- ***************************************************************************** -->
	<!-- The settings below should be overriden in the buildoverrides.local.properties -->
	<!-- determine the release root -->
	<!-- ***************************************************************************** -->
	<condition property="release.dir" value="${core.project.dir}/../../../../releases/${build.baseversion}" else="${core.project.dir}/../release">
		<istrue value="${running.on.build.server}" />
	</condition>
	<property name="local.project" value="lev_pos" />
	<property name="run.project" value="lev_xstore" />

	<!-- ***************************************************************************** -->
	<!-- The settings below may/should be overridden in the buildoverrides.properties -->
	<!-- Accelerator name/version  -->
	<!-- ***************************************************************************** -->
	<property name="app.version" value="0.0" />
	<property name="app.name" value="orcs-accelerator" />
	<property name="javac.source" value="1.8" />
	<property name="javac.target" value="1.8" />
	<property name="javac.lint" value="-Xlint:none" />
	<property name="javac.debug" value="false" />

	<!-- ***************************************************************************** -->
	<!--	Properties that are set based on the accelerator overrides settings-->
	<!-- ***************************************************************************** -->
	<property name="xstore.artifact.dir" location="${release.dir}/xstore" />
	<property name="jar.name" value="${app.name}-${app.version}.jar" />
	<property name="config.jar.name" value="${app.name}-${app.version}-config.jar" />
	<property name="config.customer.jar.name" value="${accelerator.customer}-${app.name}-${app.version}-config.jar" />
	<property name="jar.dtx.name" value="${app.name}-dtx-${app.version}.jar" />
	<property name="src" location="${basedir}/src" />
	<property name="gen" location="${basedir}/gen" />
	<property name="gen.temp" location="${basedir}/gen-temp" />
	<property name="lib" location="lib" />
	<property name="dist" location="dist" />
	<property name="dist.version" location="${dist}/${app.version}" />
	<property name="dist.package" location="${dist}/${app.name}-${app.version}.zip" />
	<property name="dist.qa.package" location="${dist}/qa-${app.name}-${app.version}.zip" />
	<property name="dist.custom.package" location="${dist}/${accelerator.customer}-${app.name}-${app.version}.zip" />
	<property name="classes" location="classes" />
	<property name="config" location="${basedir}/config" />
	<property name="cust_config" location="${basedir}/cust_config" />
	<property name="base.lib" location="${xstore.artifact.dir}/xstore/lib" />
	<property name="base.lib.ext" location="${base.lib}/ext" />

	<!-- Does config dir exists -->
	<condition property="config.dir.exists">
		<available file="${config}" type="dir" />
	</condition>

	<condition property="accelerator.customer.exists">
		<isset property="accelerator.customer" />
	</condition>

	<!-- Use a common classpath for both source and JavaDoc compilation. -->
	<path id="common.classpath">
		<fileset dir="${lib}" includes="*.jar" />
	</path>
	<path id="runtime.classpath" description="A path including all jars, classes, and configs that will be available at runtime.">
		<pathelement location="${classes}" />
		<pathelement location="${cust_config}" />
		<path refid="build.classpath" />
	</path>
	<path id="build.classpath" description="A path including all dependency libraries needed to build main application classes in this project.">
		<!-- <fileset dir="${cust.lib}" includes="*.jar" /> -->
		<fileset dir="${base.lib}" includes="*.jar" />
		<!-- <fileset dir="${cust.lib.ext}" includes="*.jar" /> -->
		<fileset dir="${base.lib.ext}" includes="*.jar" />
	</path>

	<!-- ************************************* -->
	<!-- **        SOURCE GENERATION        ** -->
	<!-- ************************************* -->
	<target name="-clean-classes" description="Cleans classes generated by this script">
		<delete>
			<fileset dir="${classes}" includes="**/*" />
		</delete>
	</target>
	<target name="-clean-dtx" description="Cleans up generated DTX objects">
		<delete dir="${gen.temp}" />
		<delete includeemptydirs="true">
			<fileset dir="${gen}" includes="**/*" />
		</delete>
	</target>
	<target name="-dtx-generation" description="Generates DTX objects" depends="-clean-dtx" if="config.dir.exists">
		<mkdir dir="${gen}" />
		<mkdir dir="${gen.temp}" />
		<taskdef name="dao-generation" classname="dtv.data2.access.impl.daogen.DAOGenAnt" classpathref="runtime.classpath" />
		<dao-generation dest="${gen}" dir="${config}" tempdir="${gen.temp}" overrideMode="true" />
		<delete dir="${gen.temp}" />
	</target>

	<macrodef name="generateXjcObjects" description="Generates objects from an xsd file">
		<attribute name="xsdpaths" />
		<attribute name="targetpackage" default="" />
		<attribute name="bindingfile" default="" />
		<attribute name="customargs" default="" />
		<sequential>
			<local name="package.parameter" />
			<condition property="package.parameter" value=" -p @{targetpackage}" else="">
				<length string="@{targetpackage}" trim="true" when="greater" length="0" />
			</condition>
			<local name="binding.parameter" />
			<condition property="binding.parameter" value=" -b @{bindingfile}" else="">
				<length string="@{bindingfile}" trim="true" when="greater" length="0" />
			</condition>
			<local name="custom.parameter" />
			<condition property="custom.parameter" value=" @{customargs}" else="">
				<length string="@{customargs}" trim="true" when="greater" length="0" />
			</condition>
			<local name="jaxb.arg.line" />
			<property name="jaxb.arg.line" value="-verbose -nv -npa -extension -mark-generated -encoding UTF-8 -enableIntrospection ${package.parameter}${custom.parameter} @{xsdpaths} -d ${gen}${binding.parameter}" />

			<echo message="Executing xjc with arguments: ${jaxb.arg.line}" />
			<exec executable="xjc">
				<arg line="${jaxb.arg.line}" />
			</exec>
		</sequential>
	</macrodef>

	<macrodef name="generateWsdlObjects" description="generates objects from an wsdl file">
		<attribute name="wsdlpaths" />
		<attribute name="targetpackage" default="" />
		<attribute name="bindingfile" default="" />
		<attribute name="customargs" default="" />
		<sequential>
			<local name="package.parameter" />
			<condition property="package.parameter" value=" -p @{targetpackage}" else="">
				<length string="@{targetpackage}" trim="true" when="greater" length="0" />
			</condition>
			<local name="binding.parameter" />
			<condition property="binding.parameter" value=" -b @{bindingfile}" else="">
				<length string="@{bindingfile}" trim="true" when="greater" length="0" />
			</condition>
			<local name="custom.parameter" />
			<condition property="custom.parameter" value=" @{customargs}" else="">
				<length string="@{customargs}" trim="true" when="greater" length="0" />
			</condition>
			<local name="wsimport.arg.line" />
			<property name="wsimport.arg.line" value="-verbose -keep -s ${gen} -Xnocompile ${package.parameter} ${custom.parameter} @{wsdlpaths} ${binding.parameter}" />
			<exec executable="wsimport">
				<arg line="${wsimport.arg.line}" />
			</exec>
		</sequential>
	</macrodef>

	<!-- ************************************* -->
	<!-- ** COMPILE                         ** -->
	<!-- ************************************* -->
	<macrodef name="compilejava" description="Compiles java sources">
		<attribute name="srcdir" />
		<attribute name="destdir" />
		<attribute name="classpathref" />
		<sequential>
			<mkdir dir="@{destdir}" />
			<javac srcdir="@{srcdir}" destdir="@{destdir}" classpathref="@{classpathref}" deprecation="true" debug="true" fork="true" memoryMaximumSize="256m" includeantruntime="false" />
		</sequential>
	</macrodef>

	<target name="-jar" depends="-compile,-remove-old-jars" description="Creates a jar file containing source, JavaDoc, and compiled code.">
		<jar jarfile="${lib}/${jar.name}" compress="true">
			<manifest>
				<attribute name="Built-By" value="${user.name}" />
				<attribute name="Build-Time" value="${start.TODAY} at ${start.TSTAMP}" />
				<attribute name="Build-VM-Vendor" value="${java.vm.vendor}" />
				<attribute name="Build-VM-Name" value="${java.vm.name}" />
				<attribute name="Build-VM-Version" value="${java.vm.version}" />
				<attribute name="Build-OS" value="${os.name} (${os.arch}) version ${os.version}" />
				<attribute name="Hudson-Job-Name" value="${env.JOB_NAME}" />
				<attribute name="Hudson-Build-Number" value="${env.BUILD_NUMBER}" />
				<attribute name="SVN-Revision" value="${env.SVN_REVISION}" />
				<attribute name="Main-Class" value="${jar.main-class}" />
				<attribute name="Class-Path" value="${libs.project}" />
			</manifest>
			<fileset dir="${classes}">
				<include name="**/*" />
				<!--		Exclude the customer impl dtx classes-->
				<exclude name="dtv/data2/access/impl/DataModelFactoryCustomerImpl*.class" />
				<exclude name="dtv/data2/access/impl/jdbc/JDBCAdapterMapCustomerImpl*.class" />
			</fileset>
			<fileset dir="${src}" includes="**/*.xml" />
			<fileset dir="${src}" includes="**/*.xsd" />
		</jar>

		<!--		Create a separate jar file for dtx classes-->
		<jar jarfile="${lib}/${jar.dtx.name}" compress="true" whenmanifestonly="skip">
			<manifest>
				<attribute name="Built-By" value="${user.name}" />
				<attribute name="Build-Time" value="${start.TODAY} at ${start.TSTAMP}" />
				<attribute name="Build-VM-Vendor" value="${java.vm.vendor}" />
				<attribute name="Build-VM-Name" value="${java.vm.name}" />
				<attribute name="Build-VM-Version" value="${java.vm.version}" />
				<attribute name="Build-OS" value="${os.name} (${os.arch}) version ${os.version}" />
				<attribute name="Hudson-Job-Name" value="${env.JOB_NAME}" />
				<attribute name="Hudson-Build-Number" value="${env.BUILD_NUMBER}" />
				<attribute name="SVN-Revision" value="${env.SVN_REVISION}" />
				<attribute name="Main-Class" value="${jar.main-class}" />
				<attribute name="Class-Path" value="${libs.project}" />
			</manifest>
			<fileset dir="${classes}">
				<include name="dtv/data2/access/impl/DataModelFactoryCustomerImpl*.class" />
				<include name="dtv/data2/access/impl/jdbc/JDBCAdapterMapCustomerImpl*.class" />
			</fileset>
		</jar>

	</target>

	<target name="-compile" description="Performs any pre-requisite steps, then compiles the java sources that will be included in the build">
		<mkdir dir="${classes}" />
		<compilejava srcdir="${src}:${gen}" destdir="${classes}" classpathref="build.classpath" />
	</target>

	<target name="-remove-old-jars" description="Remove old jars from older versions">
		<delete verbose="true" failonerror="false">
			<fileset dir="${lib}">
				<include name="${app.name}-*.jar" />
				<exclude name="${jar.name}" />
				<exclude name="${jar.dtx.name}" />
			</fileset>
		</delete>
	</target>

	<!-- ************************************* -->
	<!-- **        COPY LOCAL PROJECT       ** -->
	<!-- ************************************* -->
	<target name="-local-project" depends="-local-project-customer" description="Copy files into the local project">

		<!-- remove old jar from the local project -->
		<delete verbose="true" failonerror="false">
			<fileset dir="../${local.project}/lib">
				<include name="${app.name}-*.jar" />
				<exclude name="${jar.name}" />
				<exclude name="${jar.dtx.name}" />
			</fileset>
		</delete>

		<!-- remove old jar from the run project -->
		<delete verbose="true" failonerror="false">
			<fileset dir="../${run.project}/lib">
				<include name="${app.name}-*.jar" />
				<exclude name="${jar.name}" />
				<exclude name="${jar.dtx.name}" />
			</fileset>
		</delete>

		<!-- copy the dist jar file to the local project -->
		<copy todir="../${local.project}/lib">
			<fileset dir="${lib}">
				<include name="*.jar" />
				<exclude name="${jar.dtx.name}" />
			</fileset>
		</copy>

		<!-- copy the dist jar file to the run project -->
		<copy todir="../${run.project}/lib">
			<fileset dir="${lib}">
				<include name="*.jar" />
				<exclude name="${jar.dtx.name}" />
			</fileset>
		</copy>

		<!-- copy the config files to the local project -->
		<copy todir="../${local.project}/cust_config/" verbose="true">
			<fileset dir="./cust_config/">
				<include name="**" />
				<exclude name="localconfig/accelerator_customer/**" />
			</fileset>
		</copy>

		<!-- copy the WSDL files to the local project -->
		<copy todir="../${local.project}/res/schema/wsdl">
			<fileset dir="./res/schema/wsdl" erroronmissingdir="false">
				<include name="**/*.wsdl" />
			</fileset>
		</copy>

	</target>

	<target name="-local-project-customer" description="Copy files into the customer local project" if="accelerator.customer.exists">
		<!-- copy the customer specific files into the version1/patch folder -->
		<!--		<copy todir="../${local.project}/cust_config" verbose="true">
			<fileset dir="./cust_config/localconfig/accelerator_customer/${accelerator.customer}">
				<include name="**" />
			</fileset>
		</copy>-->
	</target>


	<!-- ************************************* -->
	<!-- **       DISTRIBUTION PACKAGE      ** -->
	<!-- ************************************* -->
	<target name="-clean-dist" description="Clean existing distribution package">
		<mkdir dir="${dist}" />
		<mkdir dir="${dist.version}" />
		<delete dir="${dist.package}" />
		<delete includeemptydirs="true" failonerror="false">
			<fileset dir="${dist.version}/*" includes="**/*" />
		</delete>
	</target>

	<target name="-copy-dist" depends="-copy-dist-customer,-config-jar" description="Copy elements into the distribution package">
		<copy todir="${dist.version}/cust_config">
			<fileset dir="./cust_config" erroronmissingdir="false">
				<include name="**/*" />
				<exclude name="localconfig/**" />
			</fileset>
		</copy>
		<copy todir="${dist.version}/config">
			<fileset dir="./config" erroronmissingdir="false">
				<include name="**/*.dtx" />
			</fileset>
		</copy>
		<copy todir="${dist.version}/database">
			<fileset dir="./database" erroronmissingdir="false">
				<include name="**/*.sql" />
			</fileset>
		</copy>
		<copy todir="${dist.version}/lib">
			<fileset dir="./lib" erroronmissingdir="false">
				<include name="**/*.jar" />
				<exclude name="${jar.dtx.name}" />
			</fileset>
		</copy>
		<copy todir="${dist.version}/res/schema/wsdl">
			<fileset dir="./res/schema/wsdl" erroronmissingdir="false">
				<include name="**/*.wsdl" />
			</fileset>
		</copy>
		<copy todir="${dist.version}/updates">
			<fileset dir="./updates" erroronmissingdir="false">
				<include name="**/*" />
			</fileset>
		</copy>
		<copy todir="${dist.version}/qa">
			<fileset dir="./dev-resources/qa" erroronmissingdir="false">
				<include name="**/*" />
			</fileset>
		</copy>
		<copy todir="${dist.version}/qa/lib/patch">
			<fileset dir="${lib}">
				<include name="${jar.dtx.name}" />
			</fileset>
		</copy>
	</target>

	<target name="-copy-dist-customer" depends="-config-customer-jar" description="Copy elements into the customer specific distribution package" if="accelerator.customer.exists">
		<!--		<copy todir="${dist.version}/accelerator_customer/${accelerator.customer}/lib">
			<fileset dir="${lib}" erroronmissingdir="false">
				<include name="${config.customer.jar.name}" />
			</fileset>
		</copy>-->
	</target>

	<target name="-config-customer-jar" description="Creates a customer specfic jar file containing configuration">
		<!--		<jar jarfile="${dist.version}/accelerator_customer/${accelerator.customer}/lib/${config.customer.jar.name}" compress="true">
			<manifest>
				<attribute name="Built-By" value="${user.name}" />
				<attribute name="Build-Time" value="${start.TODAY} at ${start.TSTAMP}" />
				<attribute name="Build-VM-Vendor" value="${java.vm.vendor}" />
				<attribute name="Build-VM-Name" value="${java.vm.name}" />
				<attribute name="Build-VM-Version" value="${java.vm.version}" />
				<attribute name="Build-OS" value="${os.name} (${os.arch}) version ${os.version}" />
				<attribute name="Hudson-Job-Name" value="${env.JOB_NAME}" />
				<attribute name="Hudson-Build-Number" value="${env.BUILD_NUMBER}" />
				<attribute name="SVN-Revision" value="${env.SVN_REVISION}" />
				<attribute name="Main-Class" value="${jar.main-class}" />
				<attribute name="Class-Path" value="${libs.project}" />
			</manifest>
			<fileset dir="./cust_config/localconfig/accelerator_customer/${accelerator.customer}" erroronmissingdir="false">
				<include name="**/*" />
			</fileset>
		</jar>-->
	</target>

	<target name="-config-jar" description="Creates a jar file containing configuration">
		<jar jarfile="${dist.version}/lib/${config.jar.name}" compress="true">
			<manifest>
				<attribute name="Built-By" value="${user.name}" />
				<attribute name="Build-Time" value="${start.TODAY} at ${start.TSTAMP}" />
				<attribute name="Build-VM-Vendor" value="${java.vm.vendor}" />
				<attribute name="Build-VM-Name" value="${java.vm.name}" />
				<attribute name="Build-VM-Version" value="${java.vm.version}" />
				<attribute name="Build-OS" value="${os.name} (${os.arch}) version ${os.version}" />
				<attribute name="Hudson-Job-Name" value="${env.JOB_NAME}" />
				<attribute name="Hudson-Build-Number" value="${env.BUILD_NUMBER}" />
				<attribute name="SVN-Revision" value="${env.SVN_REVISION}" />
				<attribute name="Main-Class" value="${jar.main-class}" />
				<attribute name="Class-Path" value="${libs.project}" />
			</manifest>
			<fileset dir="./cust_config" erroronmissingdir="false">
				<include name="**/*" />
				<exclude name="localconfig/**" />
			</fileset>
		</jar>
	</target>

	<target name="-zip-dist" depends="-zip-dist-customer" description="Zip distribution package">
		<zip destfile="${dist.package}" whenempty="skip">
			<fileset dir="${dist.version}">
				<include name="*/**" />
				<exclude name="qa/**" />
				<exclude name="accelerator_customer/**" />
				<exclude name="cust_config/**" />
			</fileset>
		</zip>
		<zip destfile="${dist.qa.package}" whenempty="skip">
			<fileset dir="${dist.version}/qa">
				<include name="*/**" />
			</fileset>
		</zip>
	</target>

	<target name="-zip-dist-customer" description="Zip distribution customer specific package" if="accelerator.customer.exists">
		<!--		<zip destfile="${dist.custom.package}" whenempty="skip">
			<fileset dir="${dist.version}/accelerator_customer/${accelerator.customer}">
				<include name="*/**" />
			</fileset>
		</zip>-->
	</target>
	

	<!-- **      MAIN EXECUTABLE TASKS      ** -->
	<!-- ************************************* -->
	<target name="generation" depends="-clean-classes,-dtx-generation,custom-generation" description="Generates code" />
	<target name="make" depends="-jar,-local-project,custom-local-project" description="Creates a distribution containing the jar file and supporting files." />	
	<target name="build-dist-package" description="Build the distribution package (zipped)" depends="-clean-dist, -copy-dist, custom-dist-package, -zip-dist" />

	<!-- extensible sections of the build process -->
	<extension-point name="custom-generation" description="Generate source code" />	
	<extension-point name="custom-local-project" description="Copy files into the local project" />
	<extension-point name="custom-dist-package" description="Custom distribution package tasks" />

	<!-- now that conditions, extension-points, properties, paths, etc. have been defined, import customizations -->
	<import file="build-custom.xml" />

</project>
